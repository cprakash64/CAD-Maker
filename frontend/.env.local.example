# Frontend configuration — copy to `frontend/.env.local` and edit.
# Next.js only inlines NEXT_PUBLIC_* vars; these are PUBLIC (shipped to the
# browser), so never put secrets here.

# Base URL of the FastAPI backend (the only variable the app actually reads).
# Dev:
NEXT_PUBLIC_API_BASE=http://localhost:8000
# Production: point at your public API origin, e.g.
# NEXT_PUBLIC_API_BASE=https://api.yourdomain.com

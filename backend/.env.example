# SourceCAD backend configuration — copy to `backend/.env` and edit.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  SECRETS POLICY                                                            │
# │  - NEVER commit `backend/.env` (it is gitignored).                        │
# │  - This file must contain PLACEHOLDERS ONLY — no real keys.               │
# │  - If a real OPENAI_API_KEY / ANTHROPIC_API_KEY / JWT_SECRET was ever     │
# │    pasted into a tracked file, a shared machine, a chat, or a screen-      │
# │    share, treat it as COMPROMISED and ROTATE it immediately.              │
# │  - Run `bash scripts/check-secrets.sh` before committing.                 │
# └──────────────────────────────────────────────────────────────────────────┘

# Environment: development | staging | production
# In staging/production the app FAILS FAST unless the config below is safe.
APP_ENV=development

# Public URL the API is reachable at (used to build download links).
# In production this MUST be your real backend URL, not localhost.
PUBLIC_BASE_URL=http://localhost:8000

# Comma-separated allowed CORS origins (your frontend).
# In production set this to your real frontend origin(s); localhost is rejected.
CORS_ORIGINS=http://localhost:3000

# Exposes provider/storage status on /health + /api/provider-status for the dev
# UI. MUST be false in production.
DEV_MODE=true

# --- Auth ---
# REQUIRED in production: a strong, unique secret (the dev default is rejected).
# Generate one with:  openssl rand -hex 32
JWT_SECRET=6a47ee95fa7d1cee5ac4e8a09115179272a3c546c05e5e046f9f66203c214e98
# JWT_EXPIRE_MINUTES=10080

# --- Rate limiting (per-process, in-memory) ---
# Off in dev/test, ON by default in staging/production. Set RATE_LIMIT_ENABLED
# explicitly to force on/off in any environment. Each limit is
# "<requests>/<window_seconds>", applied per authenticated user (else per IP).
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH=10/60          # login + signup (per IP)
# RATE_LIMIT_CREATE=30/60        # design creation (CAD generation)
# RATE_LIMIT_REGENERATE=60/60    # deterministic parameter rebuilds
# RATE_LIMIT_MODIFY=30/60        # plain-English / localized / circle edits
# RATE_LIMIT_DRAWING=12/60       # drawing interpretation (vision, costly)
# RATE_LIMIT_PACKAGE=60/60       # exports, packages, drawing views
# RATE_LIMIT_DEFAULT=120/60      # fallback for any other category

# --- Database ---
# Dev defaults to a local SQLite file. DATABASE_URL is REQUIRED in production.
# The Postgres driver (psycopg[binary]) ships in requirements.txt:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/cadmaker
# SQLite (single box; persist the file on a durable volume):
# DATABASE_URL=sqlite:///./cadmaker.db

# --- Storage ---
# "local" (default) or "s3". Downloads always go through an owner-checked API route.
STORAGE_BACKEND=local
# STORAGE_DIR=./storage_data
# For S3 / S3-compatible (MinIO, Cloudflare R2, ...). S3_BUCKET is required for s3.
# S3_BUCKET=sourcecad-exports
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=            # leave blank for AWS; set for MinIO/R2
# S3_ACCESS_KEY_ID=...        # omit to use an instance role / IAM profile
# S3_SECRET_ACCESS_KEY=...
# S3_SIGNED_URL_TTL=3600

# --- LLM provider: "mock" (offline, default), "anthropic", or "openai" ---
# Keep `mock` for offline dev/tests (no keys, no cost). mock is REJECTED in prod.
LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=sk-...
# Use a model id your account can access. An invalid id is non-fatal (it degrades
# through a fallback chain), but set a valid one to avoid latency + 503s.
# OPENAI_MODEL=gpt-4.1
# OPENAI_BASE_URL=                 # for Azure / OpenAI-compatible endpoints
# OPENAI_REASONING_EFFORT=medium   # low|medium|high, for reasoning models only
# OpenAI reliability tuning:
# OPENAI_TIMEOUT_SECONDS=60
# OPENAI_MAX_RETRIES=2

# --- CAD feature-graph engine (plain-English -> CadPlan -> CadQuery) ---
# Primary generation engine. "feature_graph" (default) composes parametric
# primitives from the prompt; "legacy" uses the old template-first pipeline.
# CAD_ENGINE=feature_graph
# Planner provider/model. CAD_LLM_PROVIDER defaults to LLM_PROVIDER; the OpenAI
# planner uses CAD_LLM_MODEL with a graceful fallback chain.
# CAD_LLM_PROVIDER=openai
# CAD_LLM_MODEL=gpt-4.1

# --- Observability ---
LOG_LEVEL=INFO

      "expected_family_id": "mounting_plate",
      "expected_design_mode": "single_part",
      "expected_strategy": "deterministic_template",
      "expected_can_generate": true,
      "expects_clarification": false,
      "expects_decomposition": false,
      "export_allowed": true,
      "allowed_validation_status": ["pass", "warning"],

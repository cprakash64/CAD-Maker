        "expected": {"bbox_mm": {"x": 10, "y": 10, "z": 20}, "hole_count": 1, "through_hole_count": 1}
      },
      "expected": {
        "bbox_mm": {"x": 10, "y": 10, "z": 20},
        "hole_count": 1, "through_hole_count": 1,
